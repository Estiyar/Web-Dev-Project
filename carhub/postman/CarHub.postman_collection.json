{
  "info": {
    "name": "CarHub API",
    "description": "Complete Postman collection for the CarHub Django API. Run Register or Login first to populate access and refresh tokens automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "category_id",
      "value": "1"
    },
    {
      "key": "car_id",
      "value": "1"
    },
    {
      "key": "review_id",
      "value": "1"
    },
    {
      "key": "part_id",
      "value": "1"
    },
    {
      "key": "post_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) {",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  if (pm.environment && typeof pm.environment.set === 'function') pm.environment.set('access_token', data.access);",
                  "}",
                  "if (data.refresh) {",
                  "  pm.collectionVariables.set('refresh_token', data.refresh);",
                  "  if (pm.environment && typeof pm.environment.set === 'function') pm.environment.set('refresh_token', data.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\",\n  \"password_confirm\": \"test1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/auth/register/",
            "description": "Creates a new user and saves returned JWT tokens."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) {",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  if (pm.environment && typeof pm.environment.set === 'function') pm.environment.set('access_token', data.access);",
                  "}",
                  "if (data.refresh) {",
                  "  pm.collectionVariables.set('refresh_token', data.refresh);",
                  "  if (pm.environment && typeof pm.environment.set === 'function') pm.environment.set('refresh_token', data.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/auth/login/",
            "description": "Logs the user in and refreshes saved access/refresh tokens."
          }
        },
        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) {",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  if (pm.environment && typeof pm.environment.set === 'function') pm.environment.set('access_token', data.access);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/auth/refresh/",
            "description": "Uses the saved refresh token to obtain a new access token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/auth/logout/"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/auth/profile/"
          }
        }
      ]
